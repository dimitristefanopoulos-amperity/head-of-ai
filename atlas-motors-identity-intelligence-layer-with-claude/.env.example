# ════════════════════════════════════════════════════════════════
# GM Identity Engine — Multi-Region Configuration
# ════════════════════════════════════════════════════════════════
# Copy this to .env and fill in credentials for each region.
# Each region needs its own OAuth2 API key (Settings > API Keys),
# a draft SQL segment, and a dataset ID from browser DevTools.
#
# You only need to configure the regions you have access to.
# The app will load whichever REGION_* blocks it finds.
# ════════════════════════════════════════════════════════════════

# ── GM US ──────────────────────────────────────────────────────
REGION_US_NAME=US
REGION_US_TENANT=gmus
REGION_US_TOKEN_URL=https://gmus.amperity.com/api/v0/oauth2/token
REGION_US_CLIENT_ID=amp-xxxxxxxxxxxx
REGION_US_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REGION_US_DATABASE_ID=db-xxxxxxxxxxxxxxx
REGION_US_SEGMENT_ID=seg-xxxxxxxxxxxxxxx
REGION_US_DATASET_ID=qd-xxxxxxxxxxxxxxxxxxxxxxx

# ── GM MEO (Middle East) ──────────────────────────────────────
REGION_MEO_NAME=Middle East
REGION_MEO_TENANT=gmmeo
REGION_MEO_TOKEN_URL=https://gmmeo.amperity.com/api/v0/oauth2/token
REGION_MEO_CLIENT_ID=amp-xxxxxxxxxxxx
REGION_MEO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REGION_MEO_DATABASE_ID=db-xxxxxxxxxxxxxxx
REGION_MEO_SEGMENT_ID=seg-xxxxxxxxxxxxxxx
REGION_MEO_DATASET_ID=qd-xxxxxxxxxxxxxxxxxxxxxxx

# ── GM Mexico ─────────────────────────────────────────────────
REGION_MX_NAME=Mexico
REGION_MX_TENANT=gmmx
REGION_MX_TOKEN_URL=https://gmmx.amperity.com/api/v0/oauth2/token
REGION_MX_CLIENT_ID=amp-xxxxxxxxxxxx
REGION_MX_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REGION_MX_DATABASE_ID=db-xxxxxxxxxxxxxxx
REGION_MX_SEGMENT_ID=seg-xxxxxxxxxxxxxxx
REGION_MX_DATASET_ID=qd-xxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════
# AI Assistant Configuration (Optional - for Cortex Agent access)
# ════════════════════════════════════════════════════════════════
# MCP Bridge URL (default: http://127.0.0.1:5081)
MCP_BRIDGE_URL=http://127.0.0.1:5081

# Anthropic API key (required for MCP bridge)
ANTHROPIC_API_KEY=sk-ant-xxxxx
